# === Hub API ===
HUB_HOST=0.0.0.0
HUB_PORT=8000
HUB_ENV=production
SECRET_KEY=gere-com-openssl-rand-hex-32

# === PostgreSQL ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=secondbrain
POSTGRES_USER=sbuser
POSTGRES_PASSWORD=senha-forte-aqui
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# === Qdrant ===
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# === GitHub OAuth App ===
# Crie em: https://github.com/settings/developers → OAuth Apps
# Callback URL: https://seu-dominio.com/painel/api/auth/callback/github
GITHUB_APP_CLIENT_ID=seu-client-id
GITHUB_APP_CLIENT_SECRET=seu-client-secret
GITHUB_WEBHOOK_SECRET=gere-com-openssl-rand-hex-32
GITHUB_PAT=ghp_seu-personal-access-token

# === Claude API (para Reflection/Resumos) ===
ANTHROPIC_API_KEY=sk-ant-...

# === Embedding ===
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# === Dashboard (Next.js) ===
# Mover para docker-compose ou variáveis de ambiente do servidor
NEXTAUTH_URL=https://seu-dominio.com/painel
NEXTAUTH_SECRET=gere-com-openssl-rand-hex-32
